# ============================================================
# Sistema AFT - Portal Admin (Next.js)
# ============================================================
# Copia este archivo a .env.local y reemplaza los valores
# cp .env.local.example .env.local
# ============================================================

# --- Supabase Configuration ---
# URL de tu proyecto Supabase (obtenida en Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anon (obtenida en Settings > API)
# Usada por el cliente browser para autenticación y queries con RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# Clave service_role (obtenida en Settings > API)
# ⚠️ NUNCA exponer esta clave al cliente - solo uso en servidor/API routes
# Usada para operaciones administrativas que bypassean RLS
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# --- Opcional: URL base del portal (para callbacks y reportes) ---
# Por defecto: http://localhost:3000 en desarrollo
# NEXT_PUBLIC_APP_URL=http://localhost:3000
